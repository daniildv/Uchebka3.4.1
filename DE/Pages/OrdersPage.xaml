<Page x:Class="DE.Pages.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DE.Pages"
      mc:Ignorable="d" 
      Height="Auto" Width="Auto"
      Title="Управление заказами"
      Background="White">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Page.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <Border Grid.Row="0" 
                Background="White" 
                Padding="10"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ограничение функционала для клиента и гостя через переменную для поиска -->
                <TextBox x:Name="SearchTextBox" 
                         Grid.Column="0"
                         Height="35"
                         Padding="10,5"
                         TextChanged="SearchTextBox_TextChanged"
                         ToolTip="Поиск по номеру заказа"
                         BorderBrush="Black"
                         FontFamily="Segoe UI"
                         BorderThickness="1"
                         Background="White"
                         Visibility="{Binding RelativeSource={RelativeSource AncestorType=Page}, Path=CanInteract, Converter={StaticResource BooleanToVisibilityConverter}}"/>


                <!-- ограничение функционала для клиента и гостя через переменную для фильрации -->
                <ComboBox x:Name="StatusFilterComboBox" 
                          Grid.Column="1"
                          Width="150"
                          Height="35"
                          Margin="10,0,0,0"
                          SelectionChanged="StatusFilterComboBox_SelectionChanged"
                          FontFamily="Segoe UI"
                          BorderThickness="1"
                          Background="White"
                          Padding="5,0"
                          Visibility="{Binding RelativeSource={RelativeSource AncestorType=Page}, Path=CanInteract, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ComboBoxItem Content="Все статусы" Tag="all" IsSelected="True" FontFamily="Segoe UI"/>
                    <ComboBoxItem Content="В обработке" Tag="В обработке" FontFamily="Segoe UI"/>
                    <ComboBoxItem Content="Доставлен" Tag="Доставлен" FontFamily="Segoe UI"/>
                    <ComboBoxItem Content="Отменен" Tag="Отменен" FontFamily="Segoe UI"/>
                    <ComboBoxItem Content="Новый" Tag="Новый" FontFamily="Segoe UI"/>
                    <ComboBoxItem Content="Завершен" Tag="Завершен" FontFamily="Segoe UI"/>
                </ComboBox>


                <!-- кнопка добавления только для администратора -->
                <Button x:Name="AddOrderButton"
                        Grid.Column="2"
                        Content="Добавить заказ"
                        Background="#0046C1"
                        Foreground="White"
                        Margin="10,0,0,0"
                        Height="35"
                        Padding="10,5"
                        Click="AddOrderButton_Click"
                        Cursor="Hand"
                        BorderThickness="0"
                        FontFamily="Segoe UI"
                        FontWeight="Bold"
                        Visibility="{Binding RelativeSource={RelativeSource AncestorType=Page}, Path=IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>
        </Border>


        <Border Grid.Row="1" 
                Background="White" 
                Padding="10"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <!-- ограничение функционала для клиента и гостя через переменную для сортировки -->
                <TextBlock Text="Сортировать:" 
                           VerticalAlignment="Center" 
                           Margin="0,0,10,0"
                           Foreground="Black"
                           FontFamily="Segoe UI"
                           Visibility="{Binding RelativeSource={RelativeSource AncestorType=Page}, Path=CanInteract, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <!-- ограничение функционала для клиента и гостя через переменную выпадающего списка сортировки -->
                <ComboBox x:Name="SortComboBox" 
                          Width="200" 
                          Height="30"
                          SelectionChanged="SortComboBox_SelectionChanged"
                          BorderThickness="1"
                          FontFamily="Segoe UI"
                          Background="White"
                          Padding="5,0"
                          Visibility="{Binding RelativeSource={RelativeSource AncestorType=Page}, Path=CanInteract, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ComboBoxItem Content="Без сортировки" Tag="none" IsSelected="True"/>
                    <ComboBoxItem Content="По дате (сначала новые)" Tag="date_desc"/>
                    <ComboBoxItem Content="По дате (сначала старые)" Tag="date_asc"/>
                    <ComboBoxItem Content="По номеру (возрастание)" Tag="number_asc"/>
                    <ComboBoxItem Content="По номеру (убывание)" Tag="number_desc"/>
                </ComboBox>
            </StackPanel>
        </Border>


        <ScrollViewer Grid.Row="3" 
                      VerticalScrollBarVisibility="Auto" 
                      Background="#E1E6EA">
            <ItemsControl x:Name="OrdersList" Margin="10">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,2,0,0" 
                                Padding="10" 
                                Background="White"
                                BorderBrush="Black"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>


                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Артикул заказа: " FontWeight="Bold" Foreground="Black" FontFamily="Segoe UI"/>
                                    <TextBlock Text="{Binding OrderNumber}" Foreground="Black" FontWeight="Bold" FontFamily="Segoe UI"/>
                                </StackPanel>


                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Дата доставки: " FontWeight="Bold" Foreground="Black"/>
                                    <TextBlock Text="{Binding DeliveryDate, StringFormat='dd.MM.yyyy'}" Foreground="Black"/>
                                </StackPanel>


                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Статус заказа: " FontWeight="Bold" Foreground="Black"/>
                                    <TextBlock Text="{Binding Status}" Foreground="Black"/>
                                </StackPanel>


                                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Адрес пункта выдачи: " FontWeight="Bold" Foreground="Black"/>
                                    <TextBlock Foreground="Black">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0}, {1}, ул. {2}, д. {3}">
                                                <Binding Path="AddressNK.PostalCode"/>
                                                <Binding Path="AddressNK.City"/>
                                                <Binding Path="AddressNK.Street"/>
                                                <Binding Path="AddressNK.House"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>


                                <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="Дата заказа: " FontWeight="Bold" Foreground="Black"/>
                                    <TextBlock Text="{Binding OrderDate, StringFormat='dd.MM.yyyy'}" Foreground="Black"/>
                                </StackPanel>


                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <!-- кнопка изменить только для администратора -->
                                    <Button Content="Изменить"
                                            Background="#0046C1"
                                            Foreground="White"
                                            Width="70"
                                            Height="25"
                                            Margin="5,0"
                                            Padding="5,2"
                                            FontWeight="Bold"
                                            FontSize="11"
                                            BorderThickness="0"
                                            CommandParameter="{Binding}"
                                            Click="EditButton_Click"
                                            Cursor="Hand"
                                            Visibility="{Binding RelativeSource={RelativeSource AncestorType=Page}, Path=IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- кнопка удалить только для администратора -->
                                    <Button Content="Удалить"
                                            Background="Red"
                                            Foreground="White"
                                            Width="70"
                                            Height="25"
                                            Margin="5,0"
                                            Padding="5,2"
                                            FontWeight="Bold"
                                            FontSize="11"
                                            BorderThickness="0"
                                            CommandParameter="{Binding}"
                                            Click="DeleteButton_Click"
                                            Cursor="Hand"
                                            Visibility="{Binding RelativeSource={RelativeSource AncestorType=Page}, Path=IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
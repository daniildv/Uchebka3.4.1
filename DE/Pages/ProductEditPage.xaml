<Page x:Class="DE.Pages.ProductEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DE.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="680" d:DesignWidth="800"
      Title="Каталог товаров"
      Background="White">

    <!-- конвертер -->
    <Page.Resources>
        <local:ImageConverter x:Key="ImageConverter"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#E1E6EA">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

      
            <TextBlock x:Name="PageHeader" 
                   Grid.Row="0" Grid.ColumnSpan="2"
                   FontSize="22" 
                   FontWeight="SemiBold"
                   FontFamily="Segoe UI"
                   Margin="0,0,0,20"
                   Foreground="Black"/>

            <Border Grid.Row="1" Grid.Column="0" 
                    Margin="0,0,20,0"
                    BorderThickness="1" 
                    Padding="15"
                    Background="White"
                    CornerRadius="4"
                    BorderBrush="Black">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                
                    <TextBlock Grid.Row="0" Grid.Column="0" 
                               Text="ID:" 
                               Margin="5" 
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI"
                               Foreground="Black"/>

                    <TextBox x:Name="IdTextBox" 
                             Grid.Row="0" Grid.Column="1" 
                             Margin="5" 
                             Height="30" 
                             Padding="5"
                             IsReadOnly="True" 
                             Background="White" 
                             FontFamily="Segoe UI"
                             BorderThickness="1"
                             Foreground="Black"/>

               
                    <TextBlock Grid.Row="1" Grid.Column="0" 
                               Text="Артикул:" 
                               Margin="5" 
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI"
                               Foreground="Black"/>

                    <TextBox x:Name="ArticleTextBox" 
                             Grid.Row="1" Grid.Column="1" 
                             Margin="5" 
                             Height="30" 
                             Padding="5"
                             FontFamily="Segoe UI"
                             BorderThickness="1"
                             TextChanged="RequiredField_TextChanged"
                             ToolTip="Введите артикул товара"/>

                
                    <TextBlock Grid.Row="2" Grid.Column="0" 
                               Text="Наименование: " 
                               Margin="5" 
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI"
                               Foreground="Black"/>

                    <TextBox x:Name="NameTextBox" 
                             Grid.Row="2" Grid.Column="1" 
                             Margin="5" 
                             Height="30" 
                             Padding="5"
                             FontFamily="Segoe UI"
                             BorderThickness="1"
                             TextChanged="RequiredField_TextChanged"
                             ToolTip="Введите наименование товара"/>

              
                    <TextBlock Grid.Row="3" Grid.Column="0" 
                               Text="Категория:" 
                               Margin="5" 
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI"
                               Foreground="Black"/>

                    <ComboBox x:Name="CategoryComboBox" 
                              Grid.Row="3" Grid.Column="1" 
                              Margin="5" 
                              Height="30"
                              Padding="3"
                              FontFamily="Segoe UI"
                              BorderThickness="1"
                              Background="White"
                              SelectionChanged="RequiredField_TextChanged"
                              ToolTip="Выберите категорию товара"
                              IsEditable="True"/>

             
                    <TextBlock Grid.Row="4" Grid.Column="0" 
                               Text="Описание: " 
                               Margin="5" 
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI"
                               Foreground="Black"/>

                    <TextBox x:Name="DescriptionTextBox" 
                             Grid.Row="4" Grid.Column="1" 
                             Margin="5" 
                             Height="80" 
                             Padding="5"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Segoe UI"
                             BorderThickness="1"
                             ToolTip="Введите описание товара"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" 
                               Text="Производитель:" 
                               Margin="5" 
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI"
                               Foreground="Black"/>

                    <ComboBox x:Name="ManufacturerComboBox" 
                              Grid.Row="5" Grid.Column="1" 
                              Margin="5" 
                              Height="30"
                              Padding="3"
                              FontFamily="Segoe UI"
                              BorderThickness="1"
                              Background="White"
                              SelectionChanged="RequiredField_TextChanged"
                              ToolTip="Выберите производителя"
                              IsEditable="True"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" 
                               Text="Поставщик:" 
                               Margin="5" 
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI"
                               Foreground="Black"/>

                    <ComboBox x:Name="SupplierComboBox" 
                              Grid.Row="6" Grid.Column="1" 
                              Margin="5" 
                              Height="30"
                              Padding="3"
                              FontFamily="Segoe UI"
                              BorderThickness="1"
                              Background="White"
                              SelectionChanged="RequiredField_TextChanged"
                              ToolTip="Выберите поставщика"
                              IsEditable="True"/>

           
                    <TextBlock Grid.Row="7" Grid.Column="0" 
                               Text="Цена:" 
                               Margin="5" 
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI"
                               Foreground="Black"/>

                    <TextBox x:Name="PriceTextBox" 
                             Grid.Row="7" Grid.Column="1" 
                             Margin="5" 
                             Height="30" 
                             Padding="5"
                             FontFamily="Segoe UI"
                             BorderThickness="1"
                             TextChanged="PriceTextBox_TextChanged"
                             ToolTip="Введите цену"/>

                  
                    <TextBlock Grid.Row="8" Grid.Column="0" 
                               Text="Единица измерения:" 
                               Margin="5" 
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI"
                               Foreground="Black"/>

                    <ComboBox x:Name="UnitComboBox" 
                              Grid.Row="8" Grid.Column="1" 
                              Margin="5" 
                              Height="30"
                              Padding="3"
                              FontFamily="Segoe UI"
                              BorderThickness="1"
                              Background="White"
                              SelectionChanged="RequiredField_TextChanged"
                              ToolTip="Выберите единицу измерения"
                              IsEditable="True"/>

                    <TextBlock Grid.Row="9" Grid.Column="0" 
                               Text="Количество:" 
                               Margin="5" 
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI"
                               Foreground="Black"/>

                    <TextBox x:Name="QuantityTextBox" 
                             Grid.Row="9" Grid.Column="1" 
                             Margin="5" 
                             Height="30" 
                             Padding="5"
                             FontFamily="Segoe UI"
                             BorderThickness="1"
                             TextChanged="QuantityTextBox_TextChanged"
                             ToolTip="Введите количество"/>

                
                    <TextBlock Grid.Row="10" Grid.Column="0" 
                               Text="Скидка (%):" 
                               Margin="5" 
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI"
                               Foreground="Black"/>

                    <TextBox x:Name="DiscountTextBox" 
                             Grid.Row="10" Grid.Column="1" 
                             Margin="5" 
                             Height="30" 
                             Padding="5"
                             FontFamily="Segoe UI"
                             BorderThickness="1"
                             TextChanged="DiscountTextBox_TextChanged"
                             ToolTip="Введите скидку (0-100)"/>
                </Grid>
            </Border>

     
            <Border Grid.Row="1" Grid.Column="1"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="15"
                    Background="White"
                    BorderBrush="Black"
                    VerticalAlignment="Top"
                    Height="320">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Фото товара"
                               FontWeight="Bold"
                               FontSize="14"
                               Margin="0,0,0,10"
                               Foreground="Black"
                               FontFamily="Segoe UI"/>

                
                    <Border Grid.Row="1"
                            BorderThickness="1"
                            CornerRadius="3"
                            Background="White"
                            Padding="5"
                            Margin="0,0,0,10">

                        <Image x:Name="ProductImage" 
                               Width="280" Height="180"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Source="{Binding Photo, Converter={StaticResource ImageConverter}, FallbackValue={x:Null}}"/>
                    </Border>

            
                    <Button x:Name="ChangeImageButton"
                            Grid.Row="2"
                            Content="Изменить фото"
                            HorizontalAlignment="Center"
                            Width="140"
                            Height="32"
                            Click="ChangeImageButton_Click"
                            Background="#E1E6EA"
                            Foreground="Black"
                            FontWeight="Bold"
                            FontFamily="Segoe UI"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#0046C1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

     
            <StackPanel Grid.Row="2" Grid.ColumnSpan="2"
                        Orientation="Horizontal" 
                        HorizontalAlignment="Center"
                        Margin="0,20">

                <Button x:Name="SaveButton" 
                        Content="Сохранить" 
                        Width="120" Height="35"
                        Margin="10"
                        Click="SaveButton_Click"
                        Background="#0046C1"
                        Foreground="White"
                        FontWeight="Bold"
                        FontFamily="Segoe UI"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0046C1"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="CancelButton" 
                        Content="Отмена" 
                        Width="120" Height="35"
                        Margin="10"
                        Click="CancelButton_Click"
                        Foreground="Black"
                        FontWeight="Bold"
                        FontFamily="Segoe UI"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="Black"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
<Page x:Class="DE.Pages.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:DE.Pages"
      Height="Auto" Width="Auto"
      Title="Каталог услуг"
      Loaded="Page_Loaded"
      Background="White">

    <Page.Resources>
        <local:ImageConverter x:Key="ImageConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="DisabledElementStyle" TargetType="Control">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                    <Setter Property="Background" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DisabledTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource DisabledElementStyle}">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DisabledComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource DisabledElementStyle}">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>


        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource DisabledTextBoxStyle}">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>


        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#0046C1"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0046C1"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>


        <DataTemplate x:Key="ProductTemplate">
            <Border Margin="0,5,0,5" Padding="10" BorderBrush="Black" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="White"/>
                        <Style.Triggers>

                            <!-- скидка больше 15% - фон #2E8B57 -->
                            <DataTrigger Binding="{Binding Discount}" Value="16">
                                <Setter Property="Background" Value="#2E8B57"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Discount}" Value="17">
                                <Setter Property="Background" Value="#2E8B57"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Discount}" Value="18">
                                <Setter Property="Background" Value="#2E8B57"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Discount}" Value="19">
                                <Setter Property="Background" Value="#2E8B57"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Discount}" Value="20">
                                <Setter Property="Background" Value="#2E8B57"/>
                            </DataTrigger>

                            <!-- товара нет на складе - голубой фон -->
                            <DataTrigger Binding="{Binding Quantity}" Value="0">
                                <Setter Property="Background" Value="LightBlue"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="110"/>
                    </Grid.ColumnDefinitions>

                    <!-- изображение товара -->
                    <Button Grid.Column="0" 
                    Background="Transparent"
                    BorderThickness="0"
                    CommandParameter="{Binding}"
                    Click="Product_Click">
                        <Image Width="70" Height="70" 
                       Source="{Binding Photo, Converter={StaticResource ImageConverter}}"
                       Stretch="UniformToFill"/>
                    </Button>

                    <!-- инфа о товаре -->
                    <StackPanel Grid.Column="1" Margin="8,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <TextBlock Text="{Binding Category}" FontWeight="SemiBold" FontSize="12" Foreground="Black"/>
                            <TextBlock Text=" | " FontSize="12" Foreground="Black"/>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"/>
                        </StackPanel>

                        <TextBlock Text="{Binding Description}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,2" Foreground="Black"/>
                        <TextBlock Text="{Binding Manufacturer, StringFormat='Государственный Орган: {0}'}" FontSize="11" Margin="0,0,0,2" Foreground="Black"/>

                        <!-- блок с ценой -->
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <TextBlock Text="Цена услуги: " FontWeight="SemiBold" FontSize="13"/>

                            <!-- цена - черная, зачеркнутая если есть скидка -->
                            <TextBlock Text="{Binding Price, StringFormat={}{0:N2}}" FontSize="13">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="red"/>
                                        <Setter Property="TextDecorations" Value="None"/>
                                        <Style.Triggers>
                                            <!-- cкидка от 1% до 20% - зачеркиваем -->
                                            <DataTrigger Binding="{Binding Discount}" Value="1">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Discount}" Value="2">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Discount}" Value="3">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Discount}" Value="4">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Discount}" Value="5">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Discount}" Value="6">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Discount}" Value="7">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Discount}" Value="8">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Discount}" Value="9">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Discount}" Value="10">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Discount}" Value="11">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Discount}" Value="12">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Discount}" Value="13">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Discount}" Value="14">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Discount}" Value="15">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Discount}" Value="16">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Discount}" Value="17">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Discount}" Value="18">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Discount}" Value="19">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Discount}" Value="20">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- цена со скидкой - красная -->
                            <TextBlock Text="{Binding DiscountPrice, StringFormat={}{0:N2}}" 
                                Margin="5,0,5,0" 
                                FontSize="13" 
                                FontWeight="Bold"
                                Foreground="Black"/>

                            <TextBlock Text=" руб." FontSize="13" Foreground="Black"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="В наличии: " FontWeight="SemiBold" FontSize="11"/>
                            <TextBlock Text="{Binding Quantity}" FontWeight="Bold" FontSize="11"/>
                            <TextBlock Text=" "/>
                            <TextBlock Text="{Binding Unit}" FontWeight="Bold" FontSize="11"/>
                            <TextBlock Text="."/>

                        </StackPanel>
                    </StackPanel>

                    <!-- блок скидки и кнопка удаления -->
                    <StackPanel Grid.Column="2" 
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                        <!-- процент скидки -->
                        <TextBlock Text="{Binding Discount, StringFormat={}{0}%}" 
                          FontSize="22" 
                          FontWeight="Bold"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,5"
                          Foreground="#0046C1"/>

                        <!-- кнопка удаления -->
                        <Button x:Name="DeleteButton" 
                        Content="Удалить"
                        Background="Red"
                        Foreground="White"
                        Margin="5"
                        Padding="8,4"
                        Width="80"
                        Height="28"
                        FontSize="11"
                        FontWeight="Bold"
                        BorderThickness="0"
                        CommandParameter="{Binding}"
                        Click="DeleteButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Page}, Path=IsAdmin}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="DarkRed"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <Border Grid.Row="0" 
                Background="White" 
                Padding="10"
                BorderThickness="0,0,0,1">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- скрытия строки поиска от клиентов -->
                <TextBox x:Name="SearchTextBox" 
                         Grid.Column="0"
                         Height="35"
                         Padding="10,5"
                         TextChanged="SearchTextBox_TextChanged"
                         ToolTip="Введите текст для поиска по названию, описанию, производителю или поставщику"
                         Style="{StaticResource SearchTextBoxStyle}" 
                         FontFamily="Segoe UI"
                         BorderBrush="Black"
                         Visibility="{Binding RelativeSource={RelativeSource AncestorType=Page}, Path=CanInteract, Converter={StaticResource BooleanToVisibilityConverter}}"/>


                <Button x:Name="AddProductButton"
                        Grid.Column="1"
                        Content="Добавить товар"
                        Background="#0046C1"
                        Foreground="White"
                        Margin="10,0,0,0"
                        Height="35"
                        Padding="10,5"
                        Click="AddProductButton_Click"
                        Cursor="Hand"
                        BorderThickness="0"
                        FontWeight="Bold"
                        FontFamily="Segoe UI">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0046C1"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Page}, Path=IsAdmin}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" 
                Background="White" 
                Padding="10"
                BorderThickness="0,0,0,1">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                
                <!-- выпадающий список со статичными данными -->
                <Border BorderThickness="1" CornerRadius="3" Margin="0,0,10,0">
                    <ComboBox x:Name="SortComboBox" 
                              Width="200"
                              Height="30"
                              SelectionChanged="SortComboBox_SelectionChanged"
                              ToolTip="Выберите тип сортировки"
                              BorderThickness="0"
                              Background="White"
                              FontFamily="Segoe UI"
                              Padding="5,0"
                              Visibility="{Binding RelativeSource={RelativeSource AncestorType=Page}, Path=CanInteract, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ComboBoxItem Content="Без сортировки" Tag="none" FontFamily="Segoe UI"/>
                        <ComboBoxItem Content="По количеству (возрастание)" Tag="quantity_asc" FontFamily="Segoe UI"/>
                        <ComboBoxItem Content="По количеству (убывание)" Tag="quantity_desc" FontFamily="Segoe UI"/>
                        <ComboBoxItem Content="По цене (возрастание)" Tag="price_asc" FontFamily="Segoe UI"/>
                        <ComboBoxItem Content="По цене (убывание)" Tag="price_desc" FontFamily="Segoe UI"/>
                        <ComboBoxItem Content="По названию (А-Я)" Tag="name_asc" FontFamily="Segoe UI"/>
                        <ComboBoxItem Content="По названию (Я-А)" Tag="name_desc" FontFamily="Segoe UI"/>
                    </ComboBox>
                </Border>

                <!-- выпадающий список с данными из БД -->
                <Border BorderThickness="1" CornerRadius="3">
                    <ComboBox x:Name="SupplierFilterComboBox" 
                              Width="200"
                              Height="30"
                              SelectionChanged="SupplierFilterComboBox_SelectionChanged"
                              ToolTip="Выберите поставщика для фильтрации"
                              BorderThickness="0"
                              Background="White"
                              FontFamily="Segoe UI"
                              Padding="5,0"
                              Visibility="{Binding RelativeSource={RelativeSource AncestorType=Page}, Path=CanInteract, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Border>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="3" 
                      VerticalScrollBarVisibility="Auto"
                      Background="#E1E6EA">
            <ItemsControl x:Name="ProductsList"
                          ItemTemplate="{StaticResource ProductTemplate}" Margin="10" FontFamily="Segoe UI"/>
        </ScrollViewer>
    </Grid>
</Page>
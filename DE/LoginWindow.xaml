<Window x:Class="DE.LoginWIndow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DE"
        mc:Ignorable="d"
        Title="Авторизация" 
        Height="450" Width="550"
        Icon="/Resources/logo.ico"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="White">

    <Grid Margin="20,61,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Авторизация" 
                   FontSize="25" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center"
                   FontFamily="Segoe UI"
                   Margin="0,0,0,20"/>
        <Image Source="/Resources/logo.jpeg"
            Height="50"
            Width="50" Margin="205,-50,205,50">
        </Image>


        <!-- логин -->
        <TextBlock Grid.Row="1" Text="Логин:" FontSize="14" Margin="0,0,0,5" FontFamily="Segoe UI"/>
        <TextBox x:Name="LoginTextBox" 
                 Height="35" 
                 Grid.Row="1" 
                 Margin="0,25,0,0"
                 Padding="8,5"
                 BorderThickness="1"/>


        <!-- пароль -->
        <TextBlock Grid.Row="2" Text="Пароль" FontSize="14" Margin="0,15,0,5" FontFamily="Segoe UI"/>
        <PasswordBox x:Name="PasswordBox" 
                     Height="35" 
                     Grid.Row="2" 
                     Margin="0,40,0,0"
                     Padding="8,5"
                     BorderThickness="1"/>

        <!-- кнопки -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,55,0,15">
            <Button Content="Войти" 
                    Width="120" 
                    Height="40" 
                    Margin="0,0,15,0" 
                    Click="LoginButton_Click"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="15"
                    FontFamily="Segoe UI"
                    Cursor="Hand"
                    Background="#0046C1">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="7"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="Гость" 
                    Width="120" 
                    Height="40" 
                    Click="GuestButton_Click"
                    Foreground="Black"
                    FontWeight="Bold"
                    FontSize="15"
                    FontFamily="Segoe UI"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="7"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>